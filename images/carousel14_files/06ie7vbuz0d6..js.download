${r}`:r}

RULES:
1. PRICE/COST: Never quote a price. Give branch phone number and tell them to tap View Details.
2. GREETINGS: Respond warmly. Zero vehicle mentions unless customer brings it up.
3. VEHICLE QUERIES: Highlight 2-3 real matches from data above. Year, location, key specs — conversationally.
4. STOCK ID — MANDATORY: Whenever you mention a specific vehicle, ALWAYS include its Stock ID inline, like this: "2021 Toyota Prado (Stock #KCB123E)". No exceptions — even if just briefly mentioning it.
5. INTERESTED/PRICE INTENT: When a customer expresses interest or asks about price, remind them to quote the Stock ID when calling: "Just mention Stock #KCB123E when you call and they'll pull it up straight away."
6. NO MATCHES: Be honest. Suggest closest alternatives.
7. FOLLOW-UP: End every reply with a short natural question.
8. LENGTH: Under 110 words.
9. NEVER make up specs or details not in the data.`),f=await fetch("/api/chat",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({messages:o,system:p})});if(!f.ok)throw Error(`API ${f.status}`);let g=await f.json(),m=g.content?.find(e=>"text"===e.type)?.text||g.reply||"Apologies, something went wrong. Try again in a sec!";K([...o,{role:"assistant",content:m}]);let b={id:Date.now()+1,role:"bot",text:m,vehicles:h,showCall:d||u};G(e=>[...e,b]),x&&await fetch("https://dash.alhusnainmotors.co.ke/api/web/chat/message",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({session_token:x,message:t,ai_reply:m,ai_vehicle_cards:h.length>0?h:null,ai_show_call:d||u})})}catch(e){console.error("[VehicleChatBot]",e),G(e=>[...e,{id:Date.now()+1,role:"bot",text:"Sorry, small hiccup on my end — try again in a moment!"}])}finally{U(!1)}},[q,Q,e,Y,x,W]);(0,t.useEffect)(()=>{if(!x||!f)return;let e=0,r=setInterval(async()=>{try{let r=await fetch(`https://dash.alhusnainmotors.co.ke/api/web/chat/session/${x}`),t=await r.json();if(!t.success)return;let{admin_takeover:o,messages:i}=t.data;L(o);let a=i.filter(r=>"admin"===r.sender_type&&r.id>e);a.length>0&&(e=Math.max(...a.map(e=>e.id)),G(e=>[...e,...a.map(e=>({id:e.id+Date.now(),role:"admin",text:e.message}))]))}catch{}},5e3);return()=>clearInterval(r)},[x,f]);let er=!(h&&p)&&!x;return(0,r.jsxs)(r.Fragment,{children:[(0,r.jsx)(o.Box,{as:"button",position:"fixed",bottom:6,right:6,zIndex:9999,w:"54px",h:"54px",borderRadius:"full",bg:"blue.600",color:"white",border:"none",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",boxShadow:"0 4px 20px rgba(24,95,165,0.4)",_hover:{bg:"blue.700",transform:"scale(1.06)"},_active:{transform:"scale(0.94)"},transition:"all 0.15s",onClick:()=>g(e=>!e),"aria-label":f?"Close chat":"Chat with us",children:f?(0,r.jsx)(v,{size:21}):(0,r.jsx)(S,{size:21})}),(0,r.jsxs)(o.Box,{position:"fixed",bottom:"88px",right:6,zIndex:9998,w:{base:"ca